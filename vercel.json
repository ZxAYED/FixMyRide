{
    "version": 3,
    "builds": [
      {
        "src": "dist/server.ts",
        "use": "@vercel/node",
        "config": {
          "includeFiles": [
            "prisma/schema.prisma",
            "node_modules/.prisma/**",
            "node_modules/@prisma/**",
            "prisma/**"
          ]
        }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "src/server.ts"
      }
    ]
  }
  